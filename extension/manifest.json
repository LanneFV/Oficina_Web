{
  "manifest_version": 3,
  "name": "Tradutor Vosk YouTube",
  "version": "1.0",
  "description": "Captura áudio da aba atual para transcrição e tradução em Libras.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tradutor Vosk",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}