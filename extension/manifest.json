{
  "manifest_version": 3,
  "name": "Faz o Libras",
  "version": "1.0",
  "description": "Captura áudio da aba atual para transcrição e tradução em Libras.",
  "icons": {
   "16": "icons/icon16.jpeg",
   "32": "icons/icon32.jpeg",
   "48": "icons/icon48.jpeg",
   "128": "icons/icon128.jpeg"
 },
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Faz o Libras"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
